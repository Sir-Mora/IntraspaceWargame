    <selectionEntry type="upgrade" import="true" name="Holy Bell Procession" hidden="false" id="8988-7abf-16b8-d74b" sortIndex="13">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Holy Bell Cart" hidden="false" id="4330-0db7-7391-5c21">
          <costs>
            <cost name="Points" typeId="3513-57f3-6212-3f59" value="140"/>
          </costs>
          <profiles>
            <profile name="Holy Bell Cart (120 × 92mm)" typeId="0f74-e791-1423-bb47" typeName="Vehicle" hidden="false" id="95f8-22f1-1562-a2d2">
              <characteristics>
                <characteristic name="AP" typeId="6f3e-0c10-951f-79a3">4</characteristic>
                <characteristic name="M" typeId="6dcb-59ed-386f-0f47">1&quot;</characteristic>
                <characteristic name="RS" typeId="f5ab-f47a-e83b-e93d">-</characteristic>
                <characteristic name="WS" typeId="8eac-d857-bc43-f54a">6+</characteristic>
                <characteristic name="Front" typeId="e6cb-8d4c-6d1f-0b9f">13</characteristic>
                <characteristic name="Side" typeId="47e8-d724-9e09-78a2">13</characteristic>
                <characteristic name="Rear" typeId="a649-6921-b44c-55b6">13</characteristic>
                <characteristic name="Save" typeId="9c7d-1809-8957-b7a8">7+</characteristic>
                <characteristic name="HP" typeId="a87f-3cb8-5628-b9b5">16</characteristic>
              </characteristics>
            </profile>
            <profile name="Pushed Along" typeId="6a24-9ebc-0a52-315c" typeName="Abilities" hidden="false" id="eaf5-cd43-8b47-eee2">
              <characteristics>
                <characteristic name="Description" typeId="48e9-7c24-9d42-a0b1">If this unit is within 3&quot; of a friendly infantry model when it starts a movement action, then this unit may replace its movement with that infantry units up to 6&quot;.</characteristic>
              </characteristics>
            </profile>
            <profile name="Tolling the Bell (2 AP)" typeId="6a24-9ebc-0a52-315c" typeName="Abilities" hidden="false" id="cbe9-bdca-d65e-ea3d">
              <characteristics>
                <characteristic name="Description" typeId="48e9-7c24-9d42-a0b1">This unit may toll the bell, to do so, roll a dice for each time this ability has been used before, starting at 1 dice, then 2, and so on and so forth.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoGroups>
            <infoGroup name="Tolling the Bell Table" id="ec25-9fb5-9acc-d37a" hidden="false">
              <profiles>
                <profile name="1-3" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="476e-8ea2-7aa4-cc92">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">The Holy Bell Cart may move a extra D5&quot; inches in a straight line</characteristic>
                  </characteristics>
                </profile>
                <profile name="4-6" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="ce28-b54e-9b06-b1ca">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">All Troop units may reroll morale tests until this units next activation</characteristic>
                  </characteristics>
                </profile>
                <profile name="7-9" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="dccf-18a6-7613-0816">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">All enemy units within 24&quot; of the Holy Bell Cart must take a 11+ Morale Test, if failed that unit cannot shoot or charge in its next activation.</characteristic>
                  </characteristics>
                </profile>
                <profile name="9-11" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="2d4e-01d7-e804-25da">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">Roll a d10 for each vehicle within 12&quot; on a roll of 8+ it cracks apart and suffers D2+1 unavoidable damage</characteristic>
                  </characteristics>
                </profile>
                <profile name="12-15" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="0af0-e847-ae60-73c4">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">All friendly units within 24&quot; gain +1 attack in melee until this units next activation</characteristic>
                  </characteristics>
                </profile>
                <profile name="16-19" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="c55f-6195-be8e-6798">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">Roll a d10 for each vehicle within 15&quot; on a roll of 6+ it cracks apart and suffers D2+1 unavoidable damage</characteristic>
                  </characteristics>
                </profile>
                <profile name="20-22" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="2fe9-e74a-09a1-f0d7">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">All enemy units within 24&quot; of the Holy Bell Cart must take a 13+ Morale Test, if failed that unit gets -1 to melee until this units next activation</characteristic>
                  </characteristics>
                </profile>
                <profile name="23-25" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="2b64-530f-a6ce-98a0">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">Roll a d10 for each vehicle within 15&quot; on a roll of 5+ it cracks apart and suffers D2+1 unavoidable damage</characteristic>
                  </characteristics>
                </profile>
                <profile name="26+" typeId="9d59-0ca8-2468-c40a" typeName="Holy Bell Toll Chart" hidden="false" id="6047-cdf6-4309-3c68">
                  <characteristics>
                    <characteristic name="Effect" typeId="b613-ab95-ae0c-d979">The bell is destroyed with a massive crack, every non vehicle model within 3d5+3 inches takes a automatic strength 3 hit as their eardrums burst</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </infoGroup>
          </infoGroups>
