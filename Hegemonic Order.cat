  <selectionEntries>
    <selectionEntry type="upgrade" import="true" name="Orders Reference" hidden="false" id="e31d-e35e-c3c3-ac83" sortIndex="2">
      <profiles>
        <profile name="Keep Moving!" typeId="7b98-76b9-2e4a-4af5" typeName="Order" hidden="false" id="fede-7562-37d5-f522">
          <characteristics>
            <characteristic name="Order Effect" typeId="1f4c-2669-eed8-da03">Increase Movement by 1</characteristic>
          </characteristics>
        </profile>
        <profile name="Take Aim!" typeId="7b98-76b9-2e4a-4af5" typeName="Order" hidden="false" id="badd-eed0-e0ba-cbfc">
          <characteristics>
            <characteristic name="Order Effect" typeId="1f4c-2669-eed8-da03">Add 1 to all hit rolls</characteristic>
          </characteristics>
        </profile>
        <profile name="Ready to Melee!" typeId="7b98-76b9-2e4a-4af5" typeName="Order" hidden="false" id="37e2-3956-f352-f32c">
          <characteristics>
            <characteristic name="Order Effect" typeId="1f4c-2669-eed8-da03">Add 1 attacks to all melee weapons</characteristic>
          </characteristics>
        </profile>
        <profile name="Keep fighting!" typeId="7b98-76b9-2e4a-4af5" typeName="Order" hidden="false" id="dceb-21e6-3ae5-723c">
          <characteristics>
            <characteristic name="Order Effect" typeId="1f4c-2669-eed8-da03">the unit may shoot after taking the Fall Back action</characteristic>
          </characteristics>
        </profile>
        <profile name="Take Cover!" typeId="7b98-76b9-2e4a-4af5" typeName="Order" hidden="false" id="33d6-4e46-d98a-e1dc">
          <characteristics>
            <characteristic name="Order Effect" typeId="1f4c-2669-eed8-da03">add 1 to all cover saves if in cover, or gain a 10+ cover save if not in cover</characteristic>
          </characteristics>
        </profile>
        <profile name="Over the line!" typeId="7b98-76b9-2e4a-4af5" typeName="Order" hidden="false" id="41b1-af14-437b-bb0f">
          <characteristics>
            <characteristic name="Order Effect" typeId="1f4c-2669-eed8-da03">Add 2 to all charge rolls</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink targetId="629c-c441-50b1-a5c9" id="0c4c-ecbe-bd47-3e19" primary="true" name="Configuration"/>
      </categoryLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Regimental Orders Reference" hidden="false" id="3bea-bc69-fd7d-4875" sortIndex="4">
      <profiles>
        <profile name="Rapid Reposition!" typeId="0b14-1e44-6fd3-fc2d" typeName="Regimental order" hidden="false" id="0de9-c941-5c1f-d5c1">
          <characteristics>
            <characteristic name="Regiment" typeId="3509-7d52-d550-0e32">H.V.A.D Corps</characteristic>
            <characteristic name="Order Effect" typeId="933c-819b-89af-ff96">this unit may take a 3&quot; move order for 0 AP during their turn at any time</characteristic>
          </characteristics>
        </profile>
        <profile name="Eliminate Target" typeId="0b14-1e44-6fd3-fc2d" typeName="Regimental order" hidden="false" id="ceda-4f43-be0c-008f">
          <characteristics>
            <characteristic name="Regiment" typeId="3509-7d52-d550-0e32"/>
